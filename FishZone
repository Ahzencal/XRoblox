            lastClick = now
            local x, y = resolvePosition()
            if x and y then silentClick(x, y) end
        end
    end

    if autoTPEnabled then
        local hrp = getHRP(lp.Character)
        local insideActive, insidePart = isInsideAnyActiveZone(hrp)
        local currentStillActive = isActiveZone(currentZone)
        if not currentStillActive then
            moveToActiveZone()
        elseif not insideActive then
            moveToActiveZone()
        elseif currentZone ~= insidePart then
            tpToZone(insidePart)
        elseif frozenHRP and frozenHRP.Parent and currentZone then
            frozenHRP.Position = currentZone.Position + Vector3.new(0, currentZone.Size.Y/2 + FLOAT_HEIGHT, 0)
        end

        if currentZone and isActiveZone(currentZone) then
            ZoneStatus.Text = "Locked: " .. currentZone.Name .. " [ACTIVE]"
            ZoneStatus.TextColor3 = THEME.success
        else
            local nearest = nearestActiveZonePart()
            ZoneStatus.Text = nearest and ("Searching → " .. nearest.Name) or "No active zone"
            ZoneStatus.TextColor3 = nearest and THEME.warn or THEME.danger
        end
    else
        local nearest = nearestActiveZonePart()
        if nearest then
            ZoneStatus.Text = "Nearest active zone: " .. nearest.Name
            ZoneStatus.TextColor3 = THEME.text
        else
            ZoneStatus.Text = "No active zone"
            ZoneStatus.TextColor3 = THEME.danger
        end
    end
end)

