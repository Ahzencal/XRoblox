local function applyTheme()
    Main.BackgroundColor3 = THEME.bg
    Header.BackgroundColor3 = THEME.bg2
    HeaderMask.BackgroundColor3 = THEME.bg2
    TabsBar.BackgroundColor3 = THEME.panel
    Content.BackgroundColor3 = THEME.panel
    DragBar.BackgroundColor3 = THEME.accent
    Title.TextColor3 = THEME.text
    Sub.TextColor3 = THEME.dim
    MainStroke.Color = THEME.accent:Lerp(Color3.new(1,1,1), 0.75)
    ContentStroke.Color = THEME.accent:Lerp(Color3.new(0,0,0), 0.45)
    for _, entry in ipairs(themedButtons) do
        if entry.btn and entry.btn.Parent then
            entry.btn.BackgroundColor3 = entry.accent and THEME.accent or THEME.panel2
            entry.btn.TextColor3 = THEME.text
        end
    end
    for _, obj in ipairs(colorPreviewTargets) do
        if obj and obj.Parent then obj.BackgroundColor3 = THEME.accent end
    end
    for i, btn in ipairs(tabButtons) do
        if btn then
            if i == activeTab then
                btn.BackgroundColor3 = THEME.accent
                btn.TextColor3 = Color3.new(1,1,1)
            else
                btn.BackgroundColor3 = THEME.panel2
                btn.TextColor3 = THEME.dim
            end
        end
    end
end

