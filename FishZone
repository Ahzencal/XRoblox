        -- shrink lines out
        for _, line in ipairs(CloseLines) do
            TweenService:Create(line, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Size = UDim2.new(0,0,0,2)}):Play()
        end
        TweenService:Create(CloseText, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {TextTransparency = 1, Position = UDim2.new(0.5,0,0.42,0)}):Play()
        task.wait(0.35)
        TweenService:Create(CloseFrame, TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {BackgroundTransparency = 1}):Play()
        task.wait(0.5)
        CloseGui:Destroy()
    end)
    task.wait(0.05)
    pcall(function() ScreenGui:Destroy() end)
end

